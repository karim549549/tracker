{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "outDir": "electron/dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["electron/**/*", "shared/**/*"],
  "exclude": ["node_modules", "out", "app", "components", "hooks", "lib"]
}
